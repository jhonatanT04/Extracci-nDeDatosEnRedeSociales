# ===========================================================================
# API Keys del proyecto — copia este archivo como .env y pega tus claves
# reales. .env NUNCA se sube a git (está en .gitignore).
# ===========================================================================

# --- Groq (tier gratuito, modelos Llama, para análisis de sentimientos) ---
# https://console.groq.com/keys
GROQ_API_KEY=gsk_tu-clave-aqui
GROQ_MODEL=llama-3.1-8b-instant

# --- OpenAI (modelos GPT, para análisis de sentimientos) ---
# https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-tu-clave-aqui
OPENAI_MODEL=gpt-4o-mini

# --- YouTube Data API v3 (extracción, sin login) ---
# https://console.cloud.google.com/apis/credentials
YOUTUBE_API_KEY=tu-clave-aqui

# --- Reddit API (app tipo "script", extracción, sin login de usuario) ---
# Crear en: https://www.reddit.com/prefs/apps
REDDIT_CLIENT_ID=tu-client-id-aqui
REDDIT_CLIENT_SECRET=tu-client-secret-aqui
REDDIT_USER_AGENT=computacion-paralela-museo-ecuador/1.0

# --- Facebook (opcional: solo si se automatiza el login; por defecto se
#     inicia sesión manualmente en la ventana de Chrome que se abre) ---
FACEBOOK_USER=
FACEBOOK_PASSWORD=
