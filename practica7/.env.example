GROQ_API_KEY=gsk_tu-clave-aqui
GROQ_MODEL=llama-3.1-8b-instant

# --- OpenAI (modelos GPT) ---
# Consíguela en: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-tu-clave-aqui
OPENAI_MODEL=gpt-4o-mini
